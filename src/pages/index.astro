---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

// Get latest 3 posts (non-draft, sorted by date desc)
const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const recentPosts = allPosts
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 3);

// Get latest 3 murmurs
const allMurmurs = await getCollection('murmurs');
const recentMurmurs = allMurmurs
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 3);

function formatDate(date: Date) {
  return date.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' });
}

function truncateBody(body: string | undefined, maxLen: number = 60): string {
  if (!body) return '';
  // Strip frontmatter and markdown syntax for plain preview
  const plain = body
    .replace(/^---[\s\S]*?---\n?/, '')
    .replace(/[#*`_~\[\]]/g, '')
    .trim();
  return plain.length > maxLen ? plain.slice(0, maxLen) + '…' : plain;
}
---

<BaseLayout title="cy — 游戏数值策划 & AI Agent 探索者">
  <!-- ═══════════════════════════════════════════════════════
       HERO SECTION — F-pattern: First horizontal scan
       ═══════════════════════════════════════════════════════ -->
  <section class="border-b border-slate-800/50 bg-gradient-to-b from-slate-900/40 to-transparent">
    <div class="mx-auto max-w-5xl px-6 py-16 md:py-24">
      <!-- Eyebrow -->
      <p class="mb-3 text-sm font-medium uppercase tracking-widest text-violet-400">
        个人主页
      </p>
      <!-- Headline — most prominent, top-left weight -->
      <h1 class="mb-5 text-4xl font-bold leading-tight text-slate-100 md:text-5xl lg:text-6xl">
        你好，我是 <span class="text-violet-400">cy</span>。
      </h1>
      <!-- Sub-tagline -->
      <p class="mb-8 max-w-2xl text-lg text-slate-400 md:text-xl">
        游戏数值策划师，同时在探索 AI Agent 的实际落地——
        <br class="hidden sm:block" />
        关注复杂系统的设计与人机协作的边界。
      </p>
      <!-- CTA row -->
      <div class="flex flex-wrap gap-3">
        <a
          href="/portfolio"
          class="rounded-lg bg-violet-600 px-5 py-2.5 text-sm font-semibold text-white transition-colors hover:bg-violet-500"
        >
          查看作品集
        </a>
        <a
          href="/blog"
          class="rounded-lg border border-slate-700 px-5 py-2.5 text-sm font-semibold text-slate-300 transition-colors hover:border-slate-500 hover:text-slate-100"
        >
          阅读博客
        </a>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════
       HIGHLIGHTS — F-pattern: Second horizontal scan
       ═══════════════════════════════════════════════════════ -->
  <section class="border-b border-slate-800/50">
    <div class="mx-auto max-w-5xl px-6 py-10">
      <div class="grid grid-cols-1 gap-4 sm:grid-cols-3">
        {[
          {
            label: '专业方向',
            value: '游戏数值策划',
            icon: '♟',
            desc: '战斗系统、经济模型、数据驱动平衡',
          },
          {
            label: '技术探索',
            value: 'AI Agent 部署',
            icon: '⚙',
            desc: '多工具链编排、LLM 工作流实践',
          },
          {
            label: '当前关注',
            value: '一人公司模式',
            icon: '◈',
            desc: '独立产品化、可持续的个人商业路径',
          },
        ].map(({ label, value, icon, desc }) => (
          <div class="rounded-xl border border-slate-800 bg-slate-900/50 p-5 transition-colors hover:border-slate-700">
            <div class="mb-2 flex items-center gap-2 text-violet-400">
              <span class="text-xl">{icon}</span>
              <span class="text-xs font-medium uppercase tracking-wider text-slate-500">{label}</span>
            </div>
            <p class="mb-1 font-semibold text-slate-100">{value}</p>
            <p class="text-sm text-slate-500">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════
       MAIN CONTENT — F-pattern: Vertical left-column scan
       Left (2/3): Recent Posts | Right (1/3): About
       ═══════════════════════════════════════════════════════ -->
  <section class="mx-auto max-w-5xl px-6 py-14">
    <div class="grid grid-cols-1 gap-12 lg:grid-cols-3">

      <!-- LEFT: Recent Posts (2/3 width) -->
      <div class="lg:col-span-2">
        <div class="mb-6 flex items-center justify-between">
          <h2 class="text-xl font-bold text-slate-100">最新文章</h2>
          <a href="/blog" class="text-sm text-violet-400 hover:text-violet-300 transition-colors">
            全部文章 →
          </a>
        </div>

        <div class="space-y-5">
          {recentPosts.map((post) => {
            const slug = post.id.replace(/\.md$/, '');
            return (
              <article class="group rounded-xl border border-slate-800 bg-slate-900/30 p-5 transition-all hover:border-slate-700 hover:bg-slate-900/60">
                <div class="mb-2 flex flex-wrap items-center gap-2">
                  <time
                    datetime={post.data.pubDate.toISOString()}
                    class="text-xs text-slate-500"
                  >
                    {formatDate(post.data.pubDate)}
                  </time>
                  {post.data.tags.map((tag) => (
                    <span class="rounded-full bg-slate-800 px-2 py-0.5 text-xs text-slate-400">
                      {tag}
                    </span>
                  ))}
                </div>
                <h3 class="mb-1.5 font-semibold text-slate-100 group-hover:text-violet-300 transition-colors">
                  <a href={`/blog/${slug}`} class="after:absolute after:inset-0 relative">
                    {post.data.title}
                  </a>
                </h3>
                <p class="text-sm text-slate-500 leading-relaxed line-clamp-2">
                  {post.data.description}
                </p>
              </article>
            );
          })}
        </div>
      </div>

      <!-- RIGHT: About sidebar (1/3 width) -->
      <aside class="space-y-8">
        <!-- About Me -->
        <div>
          <h2 class="mb-4 text-xl font-bold text-slate-100">关于我</h2>
          <div class="space-y-3 text-sm text-slate-400 leading-relaxed">
            <p>
              在游戏行业从事数值策划工作，专注于战斗系统与经济模型的设计与平衡。
            </p>
            <p>
              业余时间在探索 AI Agent 的实际部署，相信人机协作是下一个十年最值得投入的方向。
            </p>
            <p>
              这里记录我的作品、思考和技术笔记。
            </p>
          </div>
        </div>

        <!-- Currently Working On -->
        <div>
          <h3 class="mb-3 text-sm font-semibold uppercase tracking-wider text-slate-500">
            近期在做
          </h3>
          <ul class="space-y-2.5">
            {[
              { text: 'OpenClaw — 多工具 AI Agent 系统', href: '/portfolio' },
              { text: '游戏数值策划案例整理', href: '/portfolio' },
              { text: '一人公司模式探索', href: '/blog/one-person-company' },
            ].map(({ text, href }) => (
              <li class="flex items-start gap-2 text-sm">
                <span class="mt-1.5 h-1.5 w-1.5 flex-shrink-0 rounded-full bg-violet-400"></span>
                <a href={href} class="text-slate-400 hover:text-slate-200 transition-colors">
                  {text}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- Recent Murmurs -->
        {recentMurmurs.length > 0 && (
          <div>
            <div class="mb-3 flex items-center justify-between">
              <h3 class="text-sm font-semibold uppercase tracking-wider text-slate-500">
                近期碎碎念
              </h3>
              <a href="/murmurs" class="text-xs text-violet-400 hover:text-violet-300 transition-colors">
                全部 →
              </a>
            </div>
            <ul class="space-y-3">
              {recentMurmurs.map((murmur) => (
                <li class="rounded-lg border border-slate-800 bg-slate-900/40 px-3 py-2.5">
                  <div class="mb-1 flex items-center gap-1.5">
                    {murmur.data.mood && (
                      <span class="text-sm leading-none">{murmur.data.mood}</span>
                    )}
                    <time class="text-xs text-slate-600">
                      {formatDate(murmur.data.pubDate)}
                    </time>
                  </div>
                  <p class="text-xs leading-relaxed text-slate-400">
                    {truncateBody(murmur.body)}
                  </p>
                </li>
              ))}
            </ul>
          </div>
        )}

        <!-- Contact -->
        <div class="rounded-xl border border-dashed border-slate-700 p-4 text-center">
          <p class="mb-3 text-sm text-slate-400">有想法？欢迎联系</p>
          <a
            href="mailto:hello@example.com"
            class="inline-block rounded-lg bg-slate-800 px-4 py-2 text-sm font-medium text-slate-300 transition-colors hover:bg-slate-700 hover:text-white"
          >
            发邮件给我
          </a>
        </div>
      </aside>
    </div>
  </section>
</BaseLayout>
