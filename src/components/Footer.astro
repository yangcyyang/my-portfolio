---
const year = new Date().getFullYear();
---

<footer class="border-t border-slate-800/60 mt-20">
  <div class="mx-auto max-w-5xl px-6 py-8 flex flex-col sm:flex-row items-center justify-between gap-4">
    <p class="text-sm text-slate-500">
      &copy; {year} cy. 用心构建。
    </p>
    <div class="flex items-center gap-5 text-sm text-slate-500">
      <a href="https://github.com" target="_blank" rel="noopener" class="hover:text-slate-300 transition-colors">
        GitHub
      </a>
      <a href="/blog" class="hover:text-slate-300 transition-colors">
        博客
      </a>
      <a href="/portfolio" class="hover:text-slate-300 transition-colors">
        作品集
      </a>
    </div>
  </div>
</footer>
