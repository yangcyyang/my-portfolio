---
const navLinks = [
  { href: '/', label: '首页' },
  { href: '/portfolio', label: '作品集' },
  { href: '/blog', label: '博客' },
  { href: '/murmurs', label: '碎碎念' },
];

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 border-b border-slate-800/60 bg-slate-950/80 backdrop-blur-md">
  <div class="mx-auto flex max-w-5xl items-center justify-between px-6 py-4">
    <!-- Logo / Site Name -->
    <a
      href="/"
      class="text-lg font-bold tracking-tight text-slate-100 transition-opacity hover:opacity-80"
    >
      <span class="text-violet-400">&lt;</span>cy<span class="text-violet-400">/&gt;</span>
    </a>

    <!-- Navigation Links -->
    <nav>
      <ul class="flex items-center gap-1">
        {
          navLinks.map(({ href, label }) => {
            const isActive =
              href === '/' ? currentPath === '/' : currentPath.startsWith(href);
            return (
              <li>
                <a
                  href={href}
                  class:list={[
                    'rounded-md px-3 py-1.5 text-sm font-medium transition-colors',
                    isActive
                      ? 'bg-violet-500/15 text-violet-300'
                      : 'text-slate-400 hover:bg-slate-800 hover:text-slate-100',
                  ]}
                >
                  {label}
                </a>
              </li>
            );
          })
        }
      </ul>
    </nav>
  </div>
</header>
